{
  "storage_root": "E:\\yangk\\storage_jiegou",
  "output_root": "./output",
  "marker": {
    "force_ocr": true,
    "use_llm": true,
    "ollama_base_url": "http://127.0.0.1:80",
    "ollama_model": "gemma4:latest",
    "llm_service": "marker.services.ollama.OllamaService",
    "strip_existing_ocr": false,
    "page_range": null,
    "model_cache_dir": "./.cache-marker/models"
  },
  "vision": {
    "enabled": true,
    "base_url": "http://127.0.0.1:80",
    "model": "gemma4:latest",
    "temperature": 0.1,
    "request_timeout_seconds": 180,
    "max_failures_per_pdf": 3,
    "max_analysis_seconds_per_pdf": 900,
    "include_level3": false,
    "max_candidate_images": 24,
    "min_image_area": 50000,
    "min_short_side": 160,
    "max_image_area": null,
    "min_aspect_ratio": 0.2,
    "max_aspect_ratio": 6.0,
    "deduplicate_images": true,
    "drop_context_keywords": [
      "logo",
      "icon",
      "copyright"
    ],
    "prefer_context_keywords": [
      "figure",
      "architecture",
      "pipeline",
      "result",
      "comparison",
      "图",
      "架构",
      "流程",
      "结果",
      "对比"
    ]
  },
  "run": {
    "resume": true,
    "show_progress": true,
    "retry_attempts": 2,
    "force_reprocess": false,
    "strict_fail": false,
    "parallel_workers": 4,
    "suppress_internal_progress": true,
    "sample_size": null,
    "gpu_mode": "round-robin",
    "gpu_devices": [0, 1, 2, 3]
  }
}